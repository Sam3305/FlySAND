# ── FastAPI Backend ────────────────────────────────────────────────────────────
# WebSocket endpoint (replace simulation intervals in useLiveFlightData.ts)
VITE_WS_URL=ws://localhost:8000/ws/flights

# REST base URL for auth and static data
VITE_API_URL=http://localhost:8000/api/v1

# ── Auth ───────────────────────────────────────────────────────────────────────
# JWT token expiry in seconds (frontend uses this for auto-logout timer)
VITE_TOKEN_TTL_SECONDS=3600

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable the live Autobooking Swarm simulation even in prod
VITE_ENABLE_SWARM_SIM=false

# ── Analytics (optional) ──────────────────────────────────────────────────────
VITE_POSTHOG_KEY=
VITE_SENTRY_DSN=
